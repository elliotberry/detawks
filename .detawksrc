{
    "dryrun": false,
    "directories": false,
    "silent": true,
    "rename": true,
  

    "ignores": [
        "node_modules",
        ".git",
        ".DS_Store"
    ],
    "sequence": [
         "replaceAmpersand",
        "toString",
       
        "trim",
        "doSwaps",
        "toParamCase"
       
    ]
}
